# Placeholder only. Copy to .env and replace values when database work begins.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth0 Regular Web Application credentials.
AUTH0_DOMAIN="your-tenant.region.auth0.com"
AUTH0_CLIENT_ID="your-auth0-client-id"
AUTH0_CLIENT_SECRET="your-auth0-client-secret"

# A 32-byte secret used to encrypt session and transaction cookies.
# Generate with: openssl rand -hex 32
AUTH0_SECRET="replace-with-a-64-character-hex-secret"

# Stable application origin. Register its /auth/callback and root URL in Auth0.
APP_BASE_URL="http://localhost:3000"
